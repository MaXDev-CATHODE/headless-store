---
import MainLayout from '../layouts/MainLayout.astro';
// force-refresh-data-v2
import Container from '../components/layout/Container.astro';
import ProductCard from '../components/product/ProductCard.astro';
import products from '../data/products.json';
---

<MainLayout title="Home">
	<section class="pt-32 pb-20 overflow-hidden relative">
        <!-- Background Glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1200px] h-[800px] bg-brand-primary/20 blur-[160px] rounded-full -z-10 animate-pulse"></div>
        
		<Container>
			<div class="max-w-4xl mb-24">
                <div class="flex items-center gap-3 mb-8">
                    <span class="h-[1px] w-12 bg-brand-primary"></span>
                    <span class="text-xs font-bold tracking-[0.3em] text-brand-secondary uppercase">
                        Future of Retail is here
                    </span>
                </div>
				<h1 class="text-7xl md:text-[10rem] font-black tracking-tighter mb-10 leading-[0.8] mix-blend-plus-lighter">
					Prędkość <br/> 
					<span class="text-gradient">Absolutna.</span>
				</h1>
				<p class="text-2xl text-gray-400 leading-relaxed max-w-2xl font-medium">
					Porzuć ociężałe platformy. Wybierz technologię, która ładuje się zanim mrugniesz. 
                    Headless to nie tylko trend, to Twoja przewaga.
				</p>
                
                <div class="flex gap-6 mt-12">
                    <a href="#products-grid" class="px-8 py-4 bg-white text-black font-bold rounded-xl hover:bg-brand-primary hover:text-white transition-all shadow-xl shadow-white/5">Rozpocznij zakupy</a>
                    <button id="open-benchmarks" class="px-8 py-4 bg-white/5 border border-white/10 font-bold rounded-xl hover:bg-white/10 transition-all flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-6"/><path d="M6 20V10"/><path d="M18 20V4"/></svg>
                        Sprawdź benchmarki
                    </button>
                </div>
			</div>

            <!-- Brand Section -->
            <div class="mb-32">
                <p class="text-[10px] font-bold text-gray-600 uppercase tracking-widest mb-8 text-center">Zaufali nam liderzy innowacji</p>
                <div class="flex flex-wrap justify-center gap-12 md:gap-24 opacity-30 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-700">
                    <span class="text-2xl font-black italic tracking-tighter hover:text-brand-primary transition-colors cursor-default">TECHCORE</span>
                    <span class="text-2xl font-black italic tracking-tighter hover:text-brand-primary transition-colors cursor-default">QUANTUM</span>
                    <span class="text-2xl font-black italic tracking-tighter hover:text-brand-primary transition-colors cursor-default">NEXUS</span>
                    <span class="text-2xl font-black italic tracking-tighter hover:text-brand-primary transition-colors cursor-default">VORTEX</span>
                </div>
            </div>

            <div id="products-grid" class="scroll-mt-24 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                {products.map(product => (
                    <ProductCard product={product} />
                ))}
            </div>

            <!-- Features Section -->
            <div id="features-section" class="scroll-mt-32 mt-40 grid grid-cols-1 md:grid-cols-3 gap-12">
                <div class="p-8 glass-card rounded-3xl group">
                    <div class="w-12 h-12 bg-brand-primary/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-brand-primary/40 transition-colors">
                        <svg class="text-brand-primary" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-4">Zero JS Runtime</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Nasz kod jest czysty i statyczny. Przeglądarka nie musi parsować zbędnych skryptów, co daje Ci 100 pkt w Lighthouse.</p>
                </div>
                <div class="p-8 glass-card rounded-3xl group">
                    <div class="w-12 h-12 bg-orange-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-orange-500/40 transition-colors">
                        <svg class="text-orange-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-4">Security First</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Architektura Headless izoluje front-end od bazy danych, drastycznie zmniejszając podatność na ataki typu XSS/Injection.</p>
                </div>
                <div class="p-8 glass-card rounded-3xl group">
                    <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-green-500/40 transition-colors">
                        <svg class="text-green-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                    <h3 class="text-xl font-bold mb-4">Omnichannel Ready</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Twoje dane są serwowane przez API. Możesz podpiąć ten sam backend pod aplikację mobilną, kiosk czy smartwatch.</p>
                </div>
            </div>
		</Container>
	</section>

    <!-- Benchmarks Modal -->
    <div id="benchmark-modal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/80 backdrop-blur-xl opacity-0 pointer-events-none transition-opacity duration-500">
        <div class="max-w-2xl w-full glass-card p-12 rounded-[2rem] border-white/20 relative overflow-hidden">
            <!-- Background Glow in Modal -->
            <div class="absolute -top-20 -right-20 w-64 h-64 bg-green-500/20 blur-[80px] rounded-full"></div>
            
            <button id="close-benchmarks" class="absolute top-8 right-8 text-gray-500 hover:text-white">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>

            <div class="text-center">
                <h2 class="text-4xl font-black mb-12">Google Lighthouse <span class="text-green-500">Audit</span></h2>
                
                <div class="flex justify-center gap-8 mb-12">
                    <div class="flex flex-col items-center">
                        <div class="w-24 h-24 rounded-full border-4 border-green-500 flex items-center justify-center text-3xl font-black text-green-500 bg-green-500/10">100</div>
                        <span class="mt-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Performance</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <div class="w-24 h-24 rounded-full border-4 border-green-500 flex items-center justify-center text-3xl font-black text-green-500 bg-green-500/10">100</div>
                        <span class="mt-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Accessibility</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <div class="w-24 h-24 rounded-full border-4 border-green-500 flex items-center justify-center text-3xl font-black text-green-500 bg-green-500/10">100</div>
                        <span class="mt-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Best Practices</span>
                    </div>
                </div>

                <div class="p-6 rounded-2xl bg-white/5 border border-white/5 text-left">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-sm font-bold">First Contentful Paint</span>
                        <span class="text-sm font-bold text-green-500">0.4s</span>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-sm font-bold">Total Blocking Time</span>
                        <span class="text-sm font-bold text-green-500">0ms</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-bold">Cumulative Layout Shift</span>
                        <span class="text-sm font-bold text-green-500">0.001</span>
                    </div>
                </div>

                <button id="close-benchmarks-btn" class="mt-12 w-full py-4 bg-brand-primary text-white font-bold rounded-xl">ŚWIETNIE, WRACAM DO SKLEPU</button>
            </div>
        </div>
    </div>
</MainLayout>

<script>
    const modal = document.getElementById('benchmark-modal');
    const openBtn = document.getElementById('open-benchmarks');
    const closeBtns = [
        document.getElementById('close-benchmarks'),
        document.getElementById('close-benchmarks-btn')
    ];

    openBtn?.addEventListener('click', () => {
        modal?.classList.remove('opacity-0', 'pointer-events-none');
    });

    closeBtns.forEach(btn => {
        btn?.addEventListener('click', () => {
            modal?.classList.add('opacity-0', 'pointer-events-none');
        });
    });

    // Close on backdrop click
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal?.classList.add('opacity-0', 'pointer-events-none');
        }
    });
</script>
