---
import MainLayout from '../../layouts/MainLayout.astro';
import Container from '../../components/layout/Container.astro';
import products from '../../data/products.json';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<MainLayout title={product.name} description={product.description}>
    <section class="py-20">
        <Container>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
                <!-- Image Gallery (Simplified for demo) -->
                <div class="glass-card rounded-3xl p-4 aspect-square">
                    <img 
                        src={product.image} 
                        alt={product.name} 
                        class="w-full h-full object-cover rounded-2xl"
                    />
                </div>

                <!-- Product Info -->
                <div class="flex flex-col h-full py-4">
                    <span class="text-brand-secondary font-bold tracking-widest text-xs uppercase mb-4">{product.category}</span>
                    <h1 class="text-5xl font-black tracking-tight mb-6">{product.name}</h1>
                    
                    <div class="text-4xl font-black mb-8">
                        {product.price} <span class="text-lg font-medium text-gray-500">{product.currency}</span>
                    </div>

                    <p class="text-gray-400 text-lg leading-relaxed mb-10">
                        {product.longDescription}
                    </p>

                    <div class="space-y-4 mb-12">
                        {product.features.map(feature => (
                            <div class="flex items-center gap-3 text-sm text-gray-300">
                                <svg class="text-brand-primary" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                {feature}
                            </div>
                        ))}
                    </div>

                    <button id="buy-button" class="w-full py-5 rounded-2xl bg-gradient-to-r from-brand-primary to-brand-secondary text-white font-black text-xl shadow-lg shadow-brand-primary/20 hover:shadow-brand-primary/40 transition-all active:scale-[0.98]">
                        KUP TERAZ
                    </button>
                </div>
            </div>
        </Container>
    </section>
</MainLayout>

<script>
    const button = document.getElementById('buy-button');
    button?.addEventListener('click', () => {
        alert('🎉 Symulacja zakupu pomyślna! Dzięki za sprawdzenie dema.');
    });
</script>
