---
import MainLayout from '../../layouts/MainLayout.astro';
// force-refresh-data-v2
import Container from '../../components/layout/Container.astro';
import ProductCard from '../../components/product/ProductCard.astro';
import products from '../../data/products.json';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const relatedProducts = products.filter(p => p.id !== product.id).slice(0, 4);
---

<MainLayout title={product.name} description={product.description}>
    <section class="py-20">
        <Container>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
                <!-- Image Gallery -->
                <div class="glass-card rounded-3xl p-6 aspect-square relative group overflow-hidden">
                    <img 
                        src={product.image} 
                        alt={product.name} 
                        class="w-full h-full object-cover rounded-2xl transition-transform duration-1000 group-hover:scale-110"
                        onerror="this.src='https://placehold.co/800x800/0f172a/4f46e5?text=Lightning+Product'"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-8">
                        <span class="text-white font-medium text-sm">Powiększ obraz +</span>
                    </div>
                </div>

                <!-- Product Info -->
                <div class="flex flex-col h-full py-4">
                    <div class="flex items-center gap-4 mb-6">
                        <span class="text-brand-secondary font-bold tracking-widest text-xs uppercase">{product.category}</span>
                        <span class="h-1 w-1 bg-gray-600 rounded-full"></span>
                        <span id="stock-counter" class="text-xs font-bold text-green-500 animate-pulse">Ładowanie stanu...</span>
                    </div>
                    
                    <h1 class="text-6xl font-black tracking-tight mb-8 leading-tight">{product.name}</h1>
                    
                    <div class="flex items-end gap-4 mb-10">
                        <div class="text-5xl font-black">
                            {product.price} <span class="text-lg font-medium text-gray-500">{product.currency}</span>
                        </div>
                        <div class="text-sm text-gray-500 line-through mb-1">{(product.price * 1.2).toFixed(0)} zł</div>
                        <span class="px-2 py-1 bg-green-500/20 text-green-500 text-[10px] font-bold rounded mb-1">-20% EARLY BIRD</span>
                    </div>

                    <div class="p-6 rounded-2xl bg-white/5 border border-white/10 mb-10">
                        <p class="text-gray-300 leading-relaxed italic">
                            "{product.longDescription}"
                        </p>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-12">
                        {product.features.map(feature => (
                            <div class="flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/5 hover:border-brand-primary/30 transition-colors group">
                                <div class="w-8 h-8 rounded-lg bg-brand-primary/10 flex items-center justify-center group-hover:bg-brand-primary/20">
                                    <svg class="text-brand-primary" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                </div>
                                <span class="text-xs font-semibold text-gray-300">{feature}</span>
                            </div>
                        ))}
                    </div>

                    <div class="flex gap-4 mb-8">
                        <button id="buy-button" class="flex-[2] py-5 rounded-2xl bg-white text-black font-black text-xl hover:bg-brand-primary hover:text-white transition-all shadow-2xl shadow-brand-primary/10 active:scale-[0.98]">
                            DODAJ DO KOSZYKA
                        </button>
                        <button class="flex-1 py-5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                        </button>
                    </div>

                    <!-- Technical Meta -->
                    <div class="flex items-center justify-between p-4 rounded-xl bg-indigo-500/5 border border-indigo-500/10 mb-8">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded bg-indigo-500/20 flex items-center justify-center text-indigo-400">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
                            </div>
                            <div>
                                <p class="text-[10px] font-black uppercase text-gray-500 tracking-tighter">Backend Data Source</p>
                                <p class="text-xs font-bold text-indigo-300">REST API / headless-cms-v2</p>
                            </div>
                        </div>
                        <button id="open-debug" class="px-3 py-1.5 rounded-lg bg-indigo-500/10 text-[9px] font-black text-indigo-400 hover:bg-indigo-500 hover:text-white transition-all uppercase">
                            View JSON Source
                        </button>
                    </div>

                    <!-- Social Proof -->
                    <div id="social-proof" class="mt-8 flex items-center gap-3 opacity-0 transition-opacity duration-1000">
                        <div class="flex -space-x-3">
                            <div class="w-8 h-8 rounded-full bg-indigo-500 border-2 border-[#0a0a0a]"></div>
                            <div class="w-8 h-8 rounded-full bg-emerald-500 border-2 border-[#0a0a0a]"></div>
                            <div class="w-8 h-8 rounded-full bg-amber-500 border-2 border-[#0a0a0a]"></div>
                        </div>
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">32 osoby oglądają ten produkt</p>
                    </div>
                </div>
            </div>

            <!-- Related Products -->
            <div class="mt-40">
                <h2 class="text-3xl font-black mb-12 flex items-center gap-4">
                    Mogą Cię <span class="text-gradient">zainteresować</span>
                    <span class="h-[1px] flex-grow bg-white/5"></span>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    {relatedProducts.map(p => <ProductCard product={p} />)}
                </div>
            </div>
        </Container>
    </section>

    <!-- Success Toast (Hidden) -->
    <div id="toast" class="fixed bottom-8 right-8 z-[100] translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
        <div class="glass-card bg-emerald-500/10 border-emerald-500/20 p-6 rounded-2xl flex items-center gap-4 shadow-2xl shadow-emerald-500/20">
            <div class="w-10 h-10 rounded-full bg-emerald-500 flex items-center justify-center text-white">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div>
                <p class="font-black text-white">DODANO DO KOSZYKA!</p>
                <p class="text-xs text-gray-400">Produkt został pomyślnie zarezerwowany.</p>
            </div>
        </div>
    </div>

    <!-- Debug Modal -->
    <div id="debug-modal" class="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-black/90 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300">
        <div class="max-w-3xl w-full glass-card p-0 rounded-3xl border-white/10 overflow-hidden shadow-2xl shadow-indigo-500/20">
            <div class="bg-white/5 border-b border-white/10 p-6 flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                    <span class="ml-4 text-xs font-bold text-gray-400 uppercase tracking-widest">Headless API Response: {product.id}.json</span>
                </div>
                <button id="close-debug-modal" class="text-gray-500 hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <pre class="p-8 overflow-auto max-h-[60vh] text-indigo-300 font-mono text-sm leading-relaxed">
{JSON.stringify(product, null, 2)}
            </pre>
            <div class="p-6 bg-indigo-500/5 text-center">
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em]">Data fetched via edge-optimized serverless function (simulated)</p>
            </div>
        </div>
    </div>
</MainLayout>

<script>
    // Elements
    const buyBtn = document.getElementById('buy-button') as HTMLButtonElement;
    const toast = document.getElementById('toast');
    const debugModal = document.getElementById('debug-modal');
    const openDebugBtn = document.getElementById('open-debug');
    const closeDebugBtn = document.getElementById('close-debug-modal');
    const stockEl = document.getElementById('stock-counter');
    const socialEl = document.getElementById('social-proof');

    // Buy Button Logic
    buyBtn?.addEventListener('click', () => {
        buyBtn.textContent = "DODAWANIE...";
        buyBtn.disabled = true;

        setTimeout(() => {
            buyBtn.textContent = "W KOSZYKU ✓";
            buyBtn.classList.add('bg-emerald-500', 'text-white');
            buyBtn.classList.remove('bg-white', 'text-black');
            
            if (toast) {
                toast.classList.remove('translate-y-20', 'opacity-0');
                setTimeout(() => {
                    toast.classList.add('translate-y-20', 'opacity-0');
                }, 4000);
            }
        }, 800);
    });

    // Debugger Logic
    openDebugBtn?.addEventListener('click', () => {
        debugModal?.classList.remove('opacity-0', 'pointer-events-none');
    });

    closeDebugBtn?.addEventListener('click', () => {
        debugModal?.classList.add('opacity-0', 'pointer-events-none');
    });

    // Stock Counter Logic
    if (stockEl) {
        setTimeout(() => {
            const count = Math.floor(Math.random() * 5) + 2;
            stockEl.textContent = `TYLKO ${count} SZTUKI W MAGAZYNIE`;
            stockEl.classList.remove('text-green-500');
            stockEl.classList.add('text-orange-500');
        }, 1500);
    }

    // Social Proof Reveal
    if (socialEl) {
        setTimeout(() => {
            socialEl.classList.remove('opacity-0');
        }, 3000);
    }
</script>
