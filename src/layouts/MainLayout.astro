---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Najszybszy sklep Headless na świecie - Demo Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Lightning Store</title>
		<!-- Google Fonts: Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen flex flex-col">
		<header class="sticky top-0 z-50 glass-card border-x-0 border-t-0 rounded-none bg-opacity-80">
			<nav class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
				<a href="/" class="text-2xl font-extrabold tracking-tighter text-gradient">LIGHTNING</a>
				<div class="flex gap-8 text-sm font-semibold text-gray-400">
					<a href="/" class="hover:text-white transition-colors">Sklep</a>
					<a href="#" class="hover:text-white transition-colors">Kategorie</a>
					<a href="#" class="hover:text-white transition-colors">O nas</a>
				</div>
			</nav>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<footer class="border-t border-white/5 py-12 mt-20">
			<div class="max-w-7xl mx-auto px-4 text-center text-gray-500 text-sm">
				<p>© 2026 Lightning Store Demo. Built with Astro & Web Performance in mind.</p>
			</div>
		</footer>
	</body>
</html>
